generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("AGENTFORGE_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("")
  goal      String   @default("")
  backstory String   @default("")
  model     String   @default("claude-sonnet-4")
  tools     String[] @default([])
  status    String   @default("active")
  runs      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flow {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  trigger     String   @default("Manual")
  steps       Json     @default("[]")
  status      String   @default("active")
  runs        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Crew {
  id        String   @id @default(cuid())
  name      String
  config    Json     @default("{}")
  status    String   @default("active")
  runs      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Automation {
  id        String   @id @default(cuid())
  name      String
  trigger   String
  agent     String
  status    String   @default("active")
  runs      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
